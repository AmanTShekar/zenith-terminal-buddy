{
  "name": "zenith-terminal-buddy",
  "displayName": "Terminal Buddy",
  "description": "Your friendly terminal companion — explains errors, suggests commands, tracks history, helps with git, and has a pet.",
  "version": "1.0.1",
  "publisher": "Zenithdev",
  "icon": "logo.png",
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AmanTShekar/zenith-terminal-buddy.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "error",
    "helper",
    "ai",
    "companion",
    "pet",
    "git"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalBuddy.openPanel",
        "title": "Terminal Buddy: Open Panel"
      },
      {
        "command": "terminalBuddy.clearHistory",
        "title": "Terminal Buddy: Clear History"
      },
      {
        "command": "terminalBuddy.setApiKey",
        "title": "Terminal Buddy: Set AI API Key"
      },
      {
        "command": "terminalBuddy.injectVaultKey",
        "title": "Terminal Buddy: Inject Vault Key"
      },
      {
        "command": "terminalBuddy.togglePet",
        "title": "Terminal Buddy: Toggle Pet Mode"
      },
      {
        "command": "terminalBuddy.explainError",
        "title": "Terminal Buddy: Explain Error"
      },
      {
        "command": "terminalBuddy.analyzeTerminal",
        "title": "Terminal Buddy: Analyze Terminal"
      },
      {
        "command": "terminalBuddy.runExecutable",
        "title": "Terminal Buddy: Run Executable"
      },
      {
        "command": "terminalBuddy.moveToDirectory",
        "title": "Terminal Buddy: Move to Directory"
      }
    ],
    "configuration": {
      "title": "Terminal Buddy",
      "properties": {
        "terminalBuddy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "[Main] Enable or disable all Terminal Buddy features."
        },
        "terminalBuddy.petEnabled": {
          "type": "boolean",
          "default": true,
          "description": "[Pet] Show your terminal companion."
        },
        "terminalBuddy.petType": {
          "type": "string",
          "default": "dragon",
          "enum": ["cat", "dog", "robot", "ghost", "dragon"],
          "enumDescriptions": [
            "A friendly cat 🐱",
            "A loyal dog 🐶",
            "A helpful robot 🤖",
            "A silly ghost 👻",
            "A powerful dragon 🐉"
          ],
          "description": "[Pet] Choose which animal or friend follows you."
        },
        "terminalBuddy.petName": {
          "type": "string",
          "default": "Zenith",
          "description": "[Pet] Give your companion a name."
        },
        "terminalBuddy.aiEnabled": {
          "type": "boolean",
          "default": false,
          "description": "[AI] Enable smart error explanations (requires an API key)."
        },
        "terminalBuddy.aiProvider": {
          "type": "string",
          "default": "gemini",
          "enum": ["gemini", "openai", "claude", "groq", "ollama", "custom"],
          "enumDescriptions": [
            "Gemini (Google) - High performance, free tier available.",
            "OpenAI (GPT-4o) - Requires a paid API key.",
            "Claude (Anthropic) - Excellent reasoning, requires API key.",
            "Groq - Ultra-fast, free tier available.",
            "Ollama - Run models locally on your own machine (No API key needed).",
            "Custom - Use any OpenAI-compatible server (LM Studio, etc.)."
          ],
          "description": "[AI] Choose which AI service should help you."
        },
        "terminalBuddy.customEndpoint": {
          "type": "string",
          "default": "http://localhost:11434/v1/chat/completions",
          "description": "[AI] URL for Ollama or Custom AI providers."
        },
        "terminalBuddy.selectedModel": {
          "type": "string",
          "default": "",
          "description": "[AI] Specific model to use (e.g. 'gemini-1.5-pro'). Leave blank for auto."
        },
        "terminalBuddy.warnOnMainPush": {
          "type": "boolean",
          "default": true,
          "description": "[Safety] Warn when pushing to main/master branches."
        },
        "terminalBuddy.enableTerminalSafety": {
          "type": "boolean",
          "default": true,
          "description": "[Safety] Check terminal commands for accidental destruction."
        },
        "terminalBuddy.enableInterception": {
          "type": "boolean",
          "default": true,
          "description": "[Safety] Pause dangerous commands until you approve them."
        },
        "terminalBuddy.scanAllPorts": {
          "type": "boolean",
          "default": false,
          "description": "[System] Monitor all active network ports (may impact performance)."
        },
        "terminalBuddy.jiraHost": {
          "type": "string",
          "default": "",
          "description": "[Jira] Your Jira Host (e.g. https://your-domain.atlassian.net)"
        },
        "terminalBuddy.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "[Jira] Your Atlassian Email address."
        },
        "terminalBuddy.jiraToken": {
          "type": "string",
          "default": "",
          "description": "[Jira] API Token for Jira Cloud or Personal Access Token for Server."
        },
        "terminalBuddy.enableVault": {
          "type": "boolean",
          "default": true,
          "description": "[Experimental] Enable the Terminal Vault for secret management."
        },
        "terminalBuddy.autoInjectEnvVars": {
          "type": "boolean",
          "default": true,
          "description": "[Experimental] Automatically inject vault secrets into new terminal sessions."
        },
        "terminalBuddy.enableAuthDetection": {
          "type": "boolean",
          "default": true,
          "description": "[Experimental] Proactively detect and prompt to inject secrets in the terminal."
        },
        "terminalBuddy.maxHistoryItems": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "maximum": 1000,
          "description": "[System] Number of command history logs to keep."
        },
        "terminalBuddy.proactiveAi": {
          "type": "boolean",
          "default": false,
          "description": "[AI] Automatically analyze terminal errors as they happen."
        },
        "terminalBuddy.agentSyncEnabled": {
          "type": "boolean",
          "default": true,
          "description": "[Sync] Share terminal context with other AI agents (like Antigravity)."
        },
        "terminalBuddy.agentContextPath": {
          "type": "string",
          "default": ".buddy/antigravity.md",
          "description": "[Sync] Path to the shared context file."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "terminalBuddy-sidebar",
          "title": "Terminal Buddy",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "terminalBuddy-sidebar": [
        {
          "id": "terminalBuddy.panel",
          "name": "Buddy Dashboard",
          "type": "webview",
          "icon": "$(terminal)"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "terminalBuddy.chat",
        "name": "buddy",
        "fullName": "Terminal Buddy",
        "description": "Analyze terminal errors and git status directly in chat.",
        "commands": [
          {
            "name": "explain",
            "description": "Analyze the last terminal error."
          },
          {
            "name": "fix",
            "description": "Suggest a fix for the terminal bug."
          },
          {
            "name": "status",
            "description": "Get current terminal health summary."
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.config.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "lint": "eslint src --ext ts",
    "test": "node ./dist/test/runTest.js",
    "verify": "npm run lint && npm run compile && npm run build"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "glob": "^10.4.2",
    "mocha": "^11.7.5",
    "typescript": "^5.5.0"
  }
}
